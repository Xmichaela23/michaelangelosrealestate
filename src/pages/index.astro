---
import Base from '../layouts/Base.astro';

const title = 'Michael Angelos';
const description =
  'Real Estate Agent in Los Angeles. Text or email Michael Angelos — The Sypek Group · Compass.';
const phone = '3232528989';
const email = 'michael@michaelangelos.realestate';
---

<Base title={title} description={description} ogUrl="https://michaelangelos.realestate/">
  <main class="card">
    <div class="card-portrait">
      <img src="/portrait.jpg" alt="Michael Angelos" width="864" height="1296" loading="eager" />
    </div>

    <div class="card-body">
      <div class="card-inner">
        <img
          class="card-logo"
          src="/logo-white.png"
          alt="The Sypek Group · Compass"
          width="220"
          height="31"
          loading="eager"
        />

        <h1 class="card-name"><span>Michael</span><span>Angelos</span></h1>
        <p class="card-role">Real Estate Agent · Los Angeles</p>
        <p class="card-dre">CalDRE# 02283132</p>

        <div class="card-actions">
          <a class="card-btn" href={`sms:+1${phone}`}>Text</a>
          <a class="card-btn" href={`mailto:${email}`}>Email</a>
          <a
            class="card-btn card-btn-save"
            href="/michael-angelos.vcf"
            download="Michael-Angelos.vcf"
          >
            Save contact
          </a>
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  .card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    min-height: 100dvh;
    background: var(--bg);
  }

  .card-portrait {
    background: var(--bg);
    overflow: hidden;
  }

  .card-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .card-body {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2.5rem;
    background: var(--bg);
  }

  .card-inner {
    width: 100%;
    max-width: 22rem;
  }

  .card-logo {
    width: auto;
    height: 2.25rem;
    margin-bottom: 2.5rem;
    filter: invert(1);
  }

  .card-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 0.92;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .card-name span {
    display: block;
  }

  .card-name span:first-child {
    font-weight: 700;
  }

  .card-name span:last-child {
    font-weight: 300;
  }

  .card-role {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .card-dre {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted-light);
    margin-bottom: 1.5rem;
  }

  .card-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
  }

  .card-btn-save {
    grid-column: 1 / -1;
  }

  .card-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--ink);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .card-btn:hover {
    background: var(--ink);
    color: var(--bg);
  }

  @media (max-width: 768px) {
    .card {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(0, 1fr) auto;
      min-height: 100dvh;
      height: 100dvh;
    }

    .card-portrait {
      min-height: 0;
    }

    .card-portrait img {
      object-fit: contain;
      object-position: center bottom;
    }

    .card-body {
      padding: 1.25rem 1.25rem 1.5rem;
      align-items: flex-start;
    }

    .card-inner {
      max-width: none;
    }

    .card-logo {
      height: 1.75rem;
      margin-bottom: 1rem;
    }

    .card-name {
      font-size: clamp(2.25rem, 12vw, 3rem);
      margin-bottom: 0.5rem;
    }

    .card-role {
      margin-bottom: 0.375rem;
      letter-spacing: 0.18em;
    }

    .card-dre {
      margin-bottom: 1rem;
    }

    .card-actions {
      gap: 0.5rem;
    }

    .card-btn {
      min-height: 2.625rem;
      padding: 0.625rem 0.75rem;
    }
  }
</style>
